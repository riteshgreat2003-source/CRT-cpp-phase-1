// Problem 6 
// Print 1 to 10 using a do-while loop

#include <iostream>
using namespace std;

int main() {
    int i = 10;
    do {
        cout << i << " ";
        i--;
    } while(i >= 1);
    return 0;
}
//problem 7
//prime number check
#include <iostream>
using namespace std;

int main(){
    int n;
    cin >> n;
    bool isPrime = true;
    
    if(n < 2){
        isPrime = false;
    }else {
        for(int i = 2; i < n; i++){
            if(n % i == 0){
                isPrime = false;
                break;
        }
    }
    }
    if(isPrime){
        cout<<"Prime Number";
    }else{
        cout<<"Not a Prime Number";
    }
    return 0;
}
