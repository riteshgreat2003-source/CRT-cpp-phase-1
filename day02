// ==============================================
// 💎 PROBLEM 03: NESTED IF-ELSE LOGIC 🕸️
// 📝 Task: Advanced validation for seniors and invalid ages
// ==============================================

#include <iostream>
using namespace std;

int main() {
    int age;
    cin >> age;
    
    if(age >= 18) {
        if (age >= 100) {
            cout <<"Eligible for Vote (But we are Super senior citizen";
        } else {
            cout <<"Eligible for Vote";
        }
    } else {
        if(age < 0) {
            cout << "Enter a Valid Age number";
        } else {
            cout << "Not Eligible for Vote";
        }
    }
    return 0;
}

// ==============================================
// 💎 PROBLEM 04: TERNARY OPERATOR ⚡
// 📝 Task: Find the greater number in a single line
// ==============================================

#include <iostream>
using namespace std;

int main() {
    int a, b;
    int max_Number;
    
    cin >> a >> b;
    // Ternary Operator
    max_Number = (a > b) ? a : b;
    
    cout << max_Number;
    return 0;
}

// ==============================================
// 💎 PROBLEM 05: CONTINUE STATEMENT ⏭️
// 📝 Task: Print 1 to N while skipping multiples of 3
// ==============================================

#include <iostream>
using namespace std;

int main() {
     int n;
     cin >> n;
    
     for(int i = 1; i <= n; i++) {
         if( i % 3 == 0){
             continue;
         }
         cout << i << " ";
     }
     return 0;
}

// ==============================================
// 💎 PROBLEM 06: BREAK STATEMENT 🛑
// 📝 Task: Continuous sum until a negative number is entered
// ==============================================

#include <iostream>
using namespace std;

int main() {
    int n;
    int sum = 0;
    
    while(true) {
       cin >> n;
       
       if(n < 0){
           break;
       }
       sum = sum + n;
    }
    cout << sum;
    return 0;
}

